"
`;

exports[`select transformer > transforms (p) => ({ category: p.category, total: sum(p.price) }) with aggregate 1`] = `
"products.select({ param: "p", paths: [["category"]], aliases: ["category"], aggregates: [{ kind: "aggregate", func: "SUM", arg: { kind: "member", param: "p", path: ["price"] }, alias: "total" }] });
"
`;

exports[`select transformer > transforms (p) => ({ cnt: count(p.id), maxSalary: max(p.salary) }) with multiple aggregates 1`] = `
"employees.select({ param: "p", paths: [], aggregates: [{ kind: "aggregate", func: "COUNT", arg: { kind: "member", param: "p", path: ["id"] }, alias: "cnt" }, { kind: "aggregate", func: "MAX", arg: { kind: "member", param: "p", path: ["salary"] }, alias: "maxSalary" }] });
"
`;

