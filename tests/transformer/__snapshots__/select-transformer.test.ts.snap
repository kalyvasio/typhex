// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`select transformer > transforms ({ id, ...rest }) => ({ id, ...rest }) to IR object with rest 1`] = `
"users.select({ param: "u", paths: [["id"]], aliases: ["id"], rest: true });
"
`;

exports[`select transformer > transforms ({ id, name }) => ({ id, name }) to IR object 1`] = `
"users.select({ param: "u", paths: [["id"], ["name"]], aliases: ["id", "name"] });
"
`;

exports[`select transformer > transforms ({ names: groupConcat(p.name, ', ') }) object with groupConcat 1`] = `
"users.select({ param: "p", paths: [], aggregates: [{ kind: "aggregate", func: "GROUP_CONCAT", arg: { kind: "member", param: "p", path: ["name"] }, alias: "names", separator: ", " }] });
"
`;

exports[`select transformer > transforms ({ unique: count(distinct(p.id)) }) object with distinct aggregate 1`] = `
"users.select({ param: "p", paths: [], aggregates: [{ kind: "aggregate", func: "COUNT", arg: { kind: "member", param: "p", path: ["id"] }, alias: "unique", distinct: true }] });
"
`;

