"class Post {
    static tableName: "posts" = "posts";
    static query(): any { return null as any; }
}
authors.where({ kind: "binary", op: ">", left: { kind: "subquery", tableName: "posts", selectIr: { param: "u", paths: [], aggregates: [{ kind: "aggregate", func: "COUNT", arg: null, alias: "count" }] }, whereIr: { kind: "binary", op: "===", left: { kind: "member", param: "p", path: ["authorId"] }, right: { kind: "member", param: "u", path: ["id"] } }, innerParamNames: ["p"], outerCorrelatedParams: ["u"] }, right: { kind: "const", value: 5 } }, {});
"
