{
  "name": "typhex",
  "version": "0.1.0",
  "description": "TypeScript ORM with arrow-function query predicates",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./transformer": {
      "types": "./dist/transformer/index.d.ts",
      "import": "./dist/transformer/index.js",
      "default": "./dist/transformer/index.js"
    },
    "./sqlite": {
      "types": "./dist/sqlite.d.ts",
      "import": "./dist/sqlite.js",
      "default": "./dist/sqlite.js"
    },
    "./postgres": {
      "types": "./dist/postgres.d.ts",
      "import": "./dist/postgres.js",
      "default": "./dist/postgres.js"
    }
  },
  "bin": {
    "typhex": "./dist/migration/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm run lint && pnpm run format:check && pnpm run build",
    "bench": "tsx benchmarks/performance.ts",
    "api:check": "pnpm run build && api-extractor run",
    "api:update": "pnpm run build && api-extractor run --local",
    "test": "vitest run",
    "test:sqlite": "vitest run --exclude 'tests/integration/scenarios-postgres.test.ts'",
    "sqlite:version": "node -e \"const Database = require('better-sqlite3'); const db = new Database(':memory:'); console.log('SQLite ' + db.prepare('select sqlite_version() as version').get().version); db.close();\"",
    "test:watch": "vitest",
    "test:postgres": "TYPHEX_POSTGRES_URL=${TYPHEX_POSTGRES_URL:-postgresql://postgres:postgres@localhost:5433/typhex_test} vitest run tests/dbs/postgres.test.ts tests/integration/scenarios-postgres.test.ts",
    "test:transformer": "vitest run tests/transformer tests/parser",
    "coverage": "vitest run --coverage",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky"
  },
  "keywords": [
    "orm",
    "typescript",
    "sql",
    "query-builder"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "acorn": "^8.14.0",
    "better-sqlite3": "^11.6.0",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.7",
    "@types/acorn": "^4.0.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.6",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "ts-patch": "^3.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.0",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.6"
  },
  "peerDependencies": {
    "typescript": ">=5.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "lint-staged": {
    "*.{ts,js,json,md,yml,yaml}": "prettier --write",
    "*.{ts,js}": "eslint --fix"
  }
}
